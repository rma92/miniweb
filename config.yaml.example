# MiniNext configuration file.
# Copy to config.yaml and edit as needed. Environment variables override file values.

server:
  listen: ":8080"
  https_enabled: false
  # cert_file: "/etc/mininext/tls.crt"
  # key_file:  "/etc/mininext/tls.key"

auth:
  enabled: false
  # static_token: "your-secret-token-here"

browser:
  engine: "chromium"
  # chromium_path: "/usr/bin/chromium"
  worker_pool_min: 1
  worker_pool_max: 4
  headless: true

session:
  idle_timeout: "10m"
  max_tabs: 10

encoding:
  default_page_format: "minidom-text"   # "minidom-text" or "mbpf"
  allow_minidom_text: true
  default_compression: "gzip"           # "gzip", "brotli", or "none"

images:
  default_format: "jpeg"    # "jpeg", "png", "gif"
  default_quality: "medium" # "high", "medium", "low"
  max_width: 800
  max_height: 1200

adblock:
  enabled: false              # set true to enable ad/tracker blocking via CDP Fetch intercept
  extra_domains: []           # additional domains to block beyond the built-in list
  # - "ads.example.com"
  # - "tracking.example.com"
  filter_list_urls:           # EasyList / uBlock Origin / ABP format lists (optional)
  # - "https://easylist.to/easylist/easylist.txt"
  # - "https://easylist.to/easylist/easyprivacy.txt"
  # - "https://raw.githubusercontent.com/uBlockOrigin/uAssets/master/filters/filters.txt"
  filter_list_refresh_hours: 24   # how often to re-download filter lists
  filter_list_cache_dir: ".adblock_cache"  # local cache for downloaded lists
